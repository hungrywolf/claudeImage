# Copy to .env and adjust if your paths differ.
# Use FORWARD slashes even on Windows — Docker Desktop accepts C:/Users/...

# Folder containing your Claude config + .bashrc (your Windows home folder).
CLAUDE_HOME=C:/Users/int3r

# The git directory mounted into the container at /workspace.
# This is your `gitdir` alias target.
GIT_DIR=C:/Users/int3r/Documents/github

# Isolated Claude config dir for the container, on the Windows PC. Seeded from
# your real ~/.claude by seed-config.sh; kept separate so in-container plugin
# installs use Linux paths and never corrupt your real config.
BOX_DIR=C:/Users/int3r/.claude-box

# Optional: pin a Claude Code version instead of latest.
# CLAUDE_VERSION=latest

# Proxy is read automatically from your host environment (HTTP_PROXY /
# HTTPS_PROXY / NO_PROXY, either case) at run time and applied to build + runtime
# (Claude API, git, npm, apt, curl). Nothing to set here normally.
# Uncomment to FORCE a value that overrides the environment:
# HTTP_PROXY=http://proxy.corp.example:8080
# HTTPS_PROXY=http://proxy.corp.example:8080
# NO_PROXY=localhost,127.0.0.1,::1
